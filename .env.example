# Public Supabase browser configuration
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=
PUBLIC_APP_URL=http://localhost:3000

# Server-only Supabase configuration
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Official YouTube and Google OAuth configuration
YOUTUBE_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_TOKEN_ENCRYPTION_KEY=

# Abuse protection
VITE_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# AI providers
GROQ_API_KEY=
GROQ_TRANSCRIPTION_MODEL=whisper-large-v3-turbo
GROQ_TEXT_MODEL=
OPENAI_API_KEY=
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_CLIP_MODEL=
OPENROUTER_API_KEY=
OPENROUTER_CLIP_MODEL=
OPENROUTER_CLIP_FALLBACK_MODELS=

# Worker and queue
WORKER_ID=video-worker-local
VIDEO_WORKER_URL=
WORKER_WAKE_SECRET=
QUEUE_POLL_INTERVAL_MS=1000
TASK_VISIBILITY_TIMEOUT_SECONDS=120
SOURCE_VALIDATION_CONCURRENCY=4
PROXY_CONCURRENCY=2
AUDIO_EXTRACTION_CONCURRENCY=3
TRANSCRIPTION_CONCURRENCY=4
AI_PLANNING_CONCURRENCY=6
PREVIEW_RENDER_CONCURRENCY=2
EXPORT_RENDER_CONCURRENCY=1
MAX_DIRECT_DOWNLOAD_BYTES=10737418240
DIRECT_DOWNLOAD_CONNECT_TIMEOUT_MS=10000
DIRECT_DOWNLOAD_READ_TIMEOUT_MS=300000
DIRECT_DOWNLOAD_REDIRECT_LIMIT=4
WORKER_TEMP_ROOT=/tmp/vidrial
WORKER_TEMP_DISK_LIMIT_BYTES=21474836480
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
FFMPEG_THREADS=1
LOG_LEVEL=info
